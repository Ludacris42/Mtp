{
  "version": 2,
  "functions": {
    "api/chat.js":   { "maxDuration": 30, "memory": 256 },
    "api/health.js": { "maxDuration": 5,  "memory": 128 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
